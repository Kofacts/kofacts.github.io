---
import BaseHead from '../../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { fetchRSSPosts } from '../../utils/rss.js';

const posts = await fetchRSSPosts();

const formatDate = (dateStr) => {
  try {
    const date = new Date(dateStr);
    if (isNaN(date.getTime())) return '';
    return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
  } catch (e) {
    return '';
  }
};
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={`Writing · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>

<main>
	<a href="/" class="profile-link">
		<span class="back-arrow">←</span>
		<img src="/ajabruwal.png" alt="" class="mini-avatar">
		<span class="mini-name">Rapheal Obodugo</span>
	</a>
	
	<header>
		<h1>Essays</h1>
		<p class="subtitle">{posts.length} essays</p>
	</header>

	<ul class="posts-grid">
		{posts.map((post) => (
			<li>
				<a href={`/blog/${post.slug}/`} class="post-card">
					<div class="post-card-content">
						<span class="title">{post.title}</span>
						{post.description && <div class="description" set:html={post.description} />}
					</div>
					<time>{formatDate(post.date)}</time>
				</a>
			</li>
		))}
	</ul>

	<footer>
		All thoughts are my own
	</footer>
</main>

<style is:global>
	* { margin: 0; padding: 0; box-sizing: border-box; }
	
	body {
		font-family: 'Inter', system-ui, sans-serif;
		background: #09090b;
		color: #a1a1aa;
		line-height: 1.65;
		-webkit-font-smoothing: antialiased;
	}
	
	main {
		max-width: 520px;
		margin: 0 auto;
		padding: 80px 24px 100px;
	}
	
	.profile-link {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
		margin-bottom: 40px;
	}
	
	.back-arrow {
		font-size: 14px;
		color: #52525b;
		transition: transform 0.2s, color 0.2s;
	}
	
	.profile-link:hover .back-arrow {
		transform: translateX(-3px);
		color: #71717a;
	}
	
	.mini-avatar {
		width: 32px;
		height: 32px;
		border-radius: 50%;
		opacity: 0.9;
	}
	
	.mini-name {
		font-size: 14px;
		color: #71717a;
		transition: color 0.2s;
	}
	
	.profile-link:hover .mini-name {
		color: #a1a1aa;
	}
	
	header {
		margin-bottom: 40px;
	}
	
	h1 {
		font-size: 20px;
		font-weight: 600;
		color: #fafafa;
		letter-spacing: -0.02em;
		margin-bottom: 4px;
	}
	
	.subtitle {
		font-size: 14px;
		color: #52525b;
	}
	
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 20px;
		list-style: none;
		margin-bottom: 56px;
	}
	
	.post-card {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 24px;
		padding: 20px;
		text-decoration: none;
		border: 1px solid #18181b;
		border-radius: 8px;
		height: 100%;
		background: #09090b;
		transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
	}
	
	.post-card:hover {
		transform: translateY(-2px);
		border-color: #3f3f46;
		background: #111113;
	}
	
	.post-card-content {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}
	
	.title {
		font-size: 15px;
		font-weight: 500;
		color: #fafafa;
		line-height: 1.4;
	}
	
	.description {
		font-size: 13px;
		color: #71717a;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	
	.post-card time {
		font-size: 12px;
		color: #52525b;
		flex-shrink: 0;
	}
	
	footer {
		padding-top: 32px;
		border-top: 1px solid #18181b;
		font-size: 12px;
		color: #27272a;
	}
	
	@media (max-width: 520px) {
		main { padding: 48px 20px 64px; }
		.posts-grid {
			grid-template-columns: 1fr;
			gap: 16px;
		}
	}
</style>

</body>
</html>